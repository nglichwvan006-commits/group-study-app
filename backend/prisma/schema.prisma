generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String? 
  name          String
  role          String         @default("MEMBER")
  isMuted       Boolean        @default(false)
  
  // Ranking fields
  totalPoints   Int            @default(0)
  level         Int            @default(1)
  badge         String         @default("Bronze")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assignments   Assignment[]   @relation("CreatedAssignments")
  submissions   Submission[]
  messages      ChatMessage[]
  warnings      Warning[]
  refreshTokens RefreshToken[]
  resources     Resource[]
  notifications Notification[]
  createdRooms  ChatRoom[]     @relation("CreatedRooms")
}

model Resource {
  id        String   @id @default(uuid())
  title     String
  url       String   
  type      String   
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Assignment {
  id          String       @id @default(uuid())
  title       String
  description String
  deadline    DateTime
  
  // Coding features
  language    String       @default("javascript")
  maxScore    Int          @default(100)
  rubric      String       @default("General correctness and code quality.")

  creatorId   String
  creator     User         @relation("CreatedAssignments", fields: [creatorId], references: [id])
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Submission {
  id           String     @id @default(uuid())
  content      String
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  
  // Grading fields
  score        Int?
  feedback     String?
  gradedAt     DateTime?
  status       String     @default("PENDING") // PENDING, GRADED, FAILED

  createdAt    DateTime   @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderId  String?
  createdAt DateTime @default(now())
}

model ChatRoom {
  id        String        @id @default(uuid())
  name      String
  code      String        @unique
  creatorId String
  creator   User          @relation("CreatedRooms", fields: [creatorId], references: [id])
  createdAt DateTime      @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  roomId    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Warning {
  id        String   @id @default(uuid())
  message   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
